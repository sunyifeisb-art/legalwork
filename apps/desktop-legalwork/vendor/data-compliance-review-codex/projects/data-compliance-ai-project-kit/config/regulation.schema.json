    "效力层级": {"type": "string"},
    "适用场景": {"type": "array", "items": {"type": "string"}},
    "相关条款": {"type": "array", "items": {"type": "string"}},
    "来源": {"type": "string"},
    "更新时间": {"type": "string"},
    "版本备注": {"type": "string"}
  }
}
